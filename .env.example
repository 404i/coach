# Environment Configuration for Garmin AI Coach

# Node Environment
NODE_ENV=production

# Encryption key for sensitive data at rest.
# Generate one with:
#   macOS / Linux:  openssl rand -hex 32
#   Windows (PowerShell):  -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#   Or use any random 64-character hex string.
ENCRYPTION_KEY=

# LLM Provider Configuration
# Choose which AI backend to use: 'lmstudio', 'ollama', or 'openai'
# - lmstudio: OpenAI-compatible API on port 1234 (supports MCP for Claude Desktop)
# - ollama: Native Ollama API on port 11434 (API-only, no MCP support)
# - openai: Official OpenAI API (requires OPENAI_API_KEY, cloud-based)
LLM_PROVIDER=lmstudio

# LM Studio Configuration
# URL to LM Studio API (default assumes LM Studio running on host machine)
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# Ollama Configuration
# URL to Ollama API (default assumes Ollama running on host machine)
# Requires LLM_PROVIDER=ollama to be active
OLLAMA_URL=http://host.docker.internal:11434

# OpenAI Configuration
# Requires LLM_PROVIDER=openai to be active
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1

# OpenWeatherMap API
# Get free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Strava API Configuration (not currently used — Garmin is the primary data source)
# Get credentials from: https://www.strava.com/settings/api
# STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET=your_strava_client_secret
# STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# Timezone
# Find your timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Port (optional, defaults in docker-compose)
PORT=8080

# Database
DB_PATH=/app/data/coach.db

# Logging
LOG_LEVEL=info

# Daily Sync Time (24h format, e.g., "06:00")
GARMIN_SYNC_TIME=06:00

# ─── Backend API Security ────────────────────────────────────────────────────
# Protects all /api/* routes (except /api/health which is always public).
# Required when the backend is reachable from other machines or untrusted networks.
# Generate one with:  openssl rand -hex 32
# Then include this header in every API request: X-Api-Key: <value>
BACKEND_API_KEY=

# ─── MCP HTTP Server Security ────────────────────────────────────────────────
# Required when running the MCP server in HTTP mode (local network access).
# Generate a secure token:  openssl rand -hex 32
# Then set it here AND in your Claude Desktop config (see mcp/claude_desktop_config_example.json)
MCP_AUTH_TOKEN=

# Port the MCP HTTP server listens on (default 3001)
MCP_PORT=3001

# Network interface to bind to.
# 127.0.0.1 = loopback only — recommended default (local machine access only)
# 0.0.0.0   = all interfaces — set this only if Claude Desktop runs on a different machine
MCP_BIND_HOST=127.0.0.1

# Max requests per IP per minute (default 60)
MCP_RATE_LIMIT=60

# Optional: comma-separated list of client IPs that may connect.
# Leave empty to allow all LAN clients (auth token still required).
# Example:  MCP_ALLOWED_IPS=192.168.1.50,192.168.1.51
MCP_ALLOWED_IPS=

# Docker Deployment Configuration
# Profile ID - unique identifier for your athlete profile
PROFILE_ID=athlete-1

# GarminDB Path - path to your GarminDB HealthData directory (for personal setup)
# macOS / Linux example: /Users/yourname/HealthData or ${HOME}/HealthData
# Windows example:        C:\Users\YourName\HealthData  (do NOT use ~ on Windows)
GARMINDB_PATH=${HOME}/HealthData

# LLM Configuration
LLM_MODEL=default
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=30000

# Fallback behavior when LM Studio unavailable
ENABLE_RULE_BASED_FALLBACK=true
