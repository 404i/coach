# Environment Configuration for Garmin AI Coach

# Node Environment
NODE_ENV=production

# LM Studio Configuration
# URL to LM Studio API (default assumes LM Studio running on host machine)
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# OpenWeatherMap API
# Get free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Strava API Configuration
# Get credentials from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# Timezone
# Find your timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Port (optional, defaults in docker-compose)
PORT=8080

# Database
DB_PATH=/app/data/coach.db

# Logging
LOG_LEVEL=info

# Daily Sync Time (24h format, e.g., "06:00")
GARMIN_SYNC_TIME=06:00

# Docker Deployment Configuration
# Profile ID - unique identifier for your athlete profile
PROFILE_ID=athlete-1

# GarminDB Path - path to your GarminDB HealthData directory (for personal setup)
# Example: /Users/yourname/HealthData or ${HOME}/HealthData
GARMINDB_PATH=${HOME}/HealthData

# LLM Configuration
LLM_MODEL=default
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=30000

# Fallback behavior when LM Studio unavailable
ENABLE_RULE_BASED_FALLBACK=true
