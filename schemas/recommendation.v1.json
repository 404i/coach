{
  "$id": "recommendation.v1",
  "type": "object",
  "required": ["profile_id", "date", "state", "recommendation_type", "recovery_score", "why", "plan_a"],
  "properties": {
    "profile_id": { "type": "string" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "state": { "type": "string", "enum": ["recover", "maintain", "build"] },
    "recommendation_type": {
      "type": "string",
      "enum": ["rest", "yoga_mobility", "easy_aerobic", "tempo_threshold", "hiit", "strength"]
    },
    "recovery_score": { "type": "number" },
    "confidence_0_1": { "type": "number", "minimum": 0, "maximum": 1 },
    "why": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal", "value", "impact"],
        "properties": {
          "signal": { "type": "string" },
          "value": {},
          "points": { "type": "number" },
          "impact": { "type": "string", "enum": ["positive", "neutral", "negative"] }
        }
      }
    },
    "safety_flags": { "type": "array", "items": { "type": "string" } },
    "gap_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap_type", "severity", "action"],
        "properties": {
          "gap_type": {
            "type": "string",
            "enum": [
              "low_aerobic_missing",
              "too_much_high_intensity",
              "no_recovery_day",
              "no_strength_mobility"
            ]
          },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "action": { "type": "string" }
        }
      }
    },
    "plan_a": {
      "type": "object",
      "required": ["title", "duration_min", "intensity", "steps"],
      "properties": {
        "title": { "type": "string" },
        "duration_min": { "type": "integer" },
        "intensity": { "type": "string", "enum": ["very_easy", "easy", "moderate", "hard"] },
        "target_zone": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "plan_b": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration_min": { "type": "integer" },
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ask_next": { "type": "array", "items": { "type": "string" } },
    "debug": { "type": "object" }
  }
}
